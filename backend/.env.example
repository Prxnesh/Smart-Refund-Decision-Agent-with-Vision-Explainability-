# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=Smart Refund Decision Agent
API_PREFIX=/api
FRONTEND_URL=http://localhost:5173

# ── Supabase Postgres ────────────────────────────────────────────────────────
# Find this in: Supabase dashboard → Project Settings → Database → Connection string
# Use the "Transaction" pooler string (port 6543) for serverless / short-lived connections.
# Example:
#   postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Supabase project credentials (optional — for future Realtime / Storage use) ──
# Find these in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service_role key>

# ── Admin login ──────────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=change-me-in-production

# ── JWT signing secret ───────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
JWT_SECRET=replace-with-a-random-64-char-hex-string

# ── Ollama (local LLM) ───────────────────────────────────────────────────────
# Make sure `ollama serve` is running and the model is pulled:
#   ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
